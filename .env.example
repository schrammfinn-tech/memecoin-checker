# =============================================================================
# DECIPHER — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your API keys
#   cp .env.example .env
# =============================================================================

# Helius RPC URL (required)
# Get a free key at: https://helius.dev
# Free tier: 100K requests/day, sufficient for personal use
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY

# Alternative: public Solana RPC (heavily rate-limited, not recommended)
# SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Web server port (default: 3000)
# Only used when running in server mode (npm run server)
PORT=3000
