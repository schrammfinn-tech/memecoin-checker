# Bubblemaps API key (get one at https://pro.bubblemaps.io)
BUBBLEMAPS_API_KEY=your_api_key_here

# Helius RPC URL for Solana (get one at https://helius.dev)
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=your_helius_key

# Alternatively, use a public RPC (heavily rate limited)
# SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Web server port
PORT=3000
