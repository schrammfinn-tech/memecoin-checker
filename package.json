{
  "name": "decipher",
  "version": "1.0.1",
  "description": "DECIPHER — On-chain analysis tool for Solana memecoins: holder clustering, bundle detection, liquidity locks, dev history tracking, social scanner, and risk scoring",
  "main": "dist/electron/main.js",
  "author": "DECIPHER",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/schrammfinn-tech/decipher"
  },
  "keywords": [
    "solana",
    "memecoin",
    "crypto",
    "token-analysis",
    "rug-check",
    "bundle-detection",
    "wallet-clustering",
    "liquidity-lock",
    "developer-history",
    "social-scanner",
    "electron"
  ],
  "scripts": {
    "build": "tsc && node -e \"const fs=require('fs');const p=require('path');const s='src/public';const d='dist/public';fs.mkdirSync(d,{recursive:true});fs.readdirSync(s).forEach(f=>fs.copyFileSync(p.join(s,f),p.join(d,f)))\"",
    "start": "electron .",
    "cli": "node dist/cli.js",
    "server": "node dist/server.js",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux"
  },
  "build": {
    "appId": "com.decipher.app",
    "productName": "DECIPHER",
    "npmRebuild": false,
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "!node_modules/bufferutil/**",
      "!node_modules/utf-8-validate/**"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": ["nsis"],
      "icon": "src/public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "target": ["dmg"]
    },
    "linux": {
      "target": ["AppImage"]
    },
    "asar": false
  },
  "dependencies": {
    "@solana/web3.js": "^1.95.0",
    "axios": "^1.7.0",
    "chalk": "^4.1.2",
    "commander": "^12.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.21.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.0"
  }
}
